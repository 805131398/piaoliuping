# ========================================
# Language Learning - 环境变量配置示例
# ========================================
# 复制此文件为 .env 并填写实际值
# cp .env.example .env
# ========================================

# 数据库配置
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/language_learning?schema=public"

# NextAuth 配置
AUTH_SECRET="your-auth-secret-here"
AUTH_URL="http://localhost:3000"

# 阿里云 OSS 配置
ALI_OSS_REGION="oss-cn-hangzhou"
ALI_OSS_ACCESS_KEY_ID=""
ALI_OSS_ACCESS_KEY_SECRET=""
ALI_OSS_BUCKET=""

# 阿里云短信配置
ALI_SMS_ACCESS_KEY_ID=""
ALI_SMS_ACCESS_KEY_SECRET=""
ALI_SMS_SIGN_NAME=""

# 邮件服务配置 (SMTP)
SMTP_HOST="smtp.example.com"
SMTP_PORT="465"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@example.com"

# 微信小程序配置
WECHAT_MINI_APPID=""
WECHAT_MINI_SECRET=""

# 微信支付配置
WECHAT_MCH_ID=""
WECHAT_API_KEY=""

# Docker 数据库配置 (仅用于 docker-compose)
DB_USER="postgres"
DB_PASSWORD="postgres"
DB_NAME="language_learning"
