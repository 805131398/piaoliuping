# Copy to .env.development for local mini-program development.

VITE_APP_TITLE="漂流瓶"
VITE_APP_PORT=9000
VITE_APP_PUBLIC_BASE="/"
VITE_APP_PROXY_ENABLE=false
VITE_APP_PROXY_PREFIX="/api"
VITE_DELETE_CONSOLE=false
VITE_AUTH_MODE=single
VITE_COPY_NATIVE_RES_ENABLE=false
VITE_FALLBACK_LOCALE="zh-Hans"

# Uni app id from DCloud, optional for local mp-weixin development.
VITE_UNI_APPID=""

# WeChat mini-program app id.
VITE_WX_APPID=""

# Must be an absolute URL. Do not use localhost on a physical phone.
VITE_SERVER_BASEURL="http://127.0.0.1:3000"

# Optional per-WeChat-version overrides.
VITE_SERVER_BASEURL__WEIXIN_DEVELOP=""
VITE_SERVER_BASEURL__WEIXIN_TRIAL=""
VITE_SERVER_BASEURL__WEIXIN_RELEASE=""
