{
  "name": "piaoliuping",
  "version": "1.0.0",
  "private": true,
  "description": "漂流瓶基础工程，保留认证、后台管理、小程序壳子、微信能力与可复用系统组件",
  "scripts": {
    "dev": "sh -c 'set -a; . ./.env; set +a; NODE_TLS_REJECT_UNAUTHORIZED=0 next dev --webpack'",
    "dev:turbo": "sh -c 'set -a; . ./.env; set +a; NODE_TLS_REJECT_UNAUTHORIZED=0 next dev --turbopack'",
    "build": "next build --webpack && cp -r public .next/standalone/ && cp -r .next/static .next/standalone/.next/",
    "start": "sh -c 'set -a; . ./.env; set +a; node .next/standalone/server.js'",
    "start:legacy": "sh -c 'set -a; . ./.env; set +a; next start'",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
